<tool id="imaginex_subhkl_prepare_peaks" name="IMAGINE-X subhkl Prepare Peaks"  profile="22.05" version="0.1.0-dev" python_template_version="3.5">
  <requirements>
    <container type="docker">ghcr.io/neutrons/subhkl:1.2.1</container>
  </requirements>
    <command detect_errors="exit_code"><![CDATA[

		mkdir out ; 

		#set $FILE_LIST = ""
		
		#for $Z in $inputs:
		    #set $BN = str($Z.input).split("/")[-1].split(".")[0]
		    #set $filename = "out/" + str($BN) + ".reduce.h5"
		    ls /SNS/MANDI/IPTS-37331 ;
		    python -m subhkl.io.parser reduce $Z.input $filename $instrument ;
		    #set $FILE_LIST = $FILE_LIST + $filename + " "
		#end for
		
		python -m subhkl.io.parser merge-images $FILE_LIST out/scan_master.h5 $a $b $c $alpha $beta $gamma $spaceGroup ;
		
    ]]></command>
    <inputs>
    
		<repeat name="inputs" title="Input Files" help="As full file paths inside /SNS">
			<param name="input" type="text" label="File" />
		</repeat>
		<param name="instrument" type="select" optional="false" value="MANDI" label="Instrument" > 
			<option value="IMAGINE">IMAGINE</option>
			<option value="CG4D">IMAGINE-X</option>
			<option value="MANDI">MANDI</option>
		</param>
	    <param name="a" type="float" value="18.39" label="a"/> 
	    <param name="b" type="float" value="56.55" label="b"/> 
	    <param name="c" type="float" value="6.54" label="c"/> 
	    <param name="alpha" type="float" value="90" label="alpha"/> 
	    <param name="beta" type="float" value="90" label="beta"/> 
	    <param name="gamma" type="float" value="90" label="gamma"/> 
	    <param name="spaceGroup" type="text" value="Fdd2" label="Space Group"/> 
		
    </inputs>
    <outputs>
		<data format="h5" label="scan.h5" name="output" from_work_dir="out/scan_master.h5" />
    </outputs>
    <help><![CDATA[
        Reduce and merge images.
    ]]></help>
</tool>
