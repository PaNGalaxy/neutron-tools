<tool id="imaginex_subhkl_peak_fit" name="IMAGINE-X subhkl Peak Finding"  profile="22.05" version="0.1.0-dev" python_template_version="3.5">
  <requirements>
    <container type="docker">ghcr.io/neutrons/subhkl:1.1.0</container>
  </requirements>
    <command detect_errors="exit_code"><![CDATA[

		mkdir out ; 
		    
		## Rename all input files to correct extensions
		mv "$scan" "$scan.element_identifier" ;    
		
		#if $algod.algo == 'thresholding' 
			#if $algod.mask.useMask 
				mv "$algod.mask.maskFile" "$algod.mask.maskFile.element_identifier" ;
			#end if
		#end if

    ]]></command>
    <inputs>
    
		<param format="h5" name="scan" type="data" label="Master scan file" />
		<param name="instrument" type="select" optional="false" value="MANDI" label="Instrument" > 
			<option value="IMAGINE">IMAGINE</option>
			<option value="CG4D">IMAGINE-X</option>
			<option value="MANDI">MANDI</option>
		</param>	
		<param name="peakBox" type="integer" value="3" label="Peak Center Box Size" /> 
		<param name="peakMin" type="integer" value="40" label="Peak Minimum Pixels" /> 
		<param name="peakSignal" type="float" value="0.0" label="Peak Minimum Signal to Noise Ratio" /> 
		<param name="peakThreshold" type="float" value="4.0" label="Peak Pixel Outlier Threshold" /> 
		<param name="peakWindow" type="integer" value="5" label="Peak Smoothing Window SIze" /> 
		<param name="growthDistance" type="float" value="1.5" label="Region Growth Distance Threshold" /> 
		<param name="growthIntensity" type="float" value="3.0" label="Region Growth Minimum Intensity" /> 
		<param name="growthRadius" type="float" value="12.0" label="Region Growth Maximum Pixel Radius" /> 
		<param name="growthSigma" type="float" value="-999.0" label="Region Growth Minimum Sigma" /> 
		<param name="wavelengthMax" type="float" value="-999.0" label="Wavelength Max" /> 
		<param name="wavelengthMin" type="float" value="999.0" label="Wavelength Min" /> 		
		<conditional name="algod">
			<param name="algo" type="select" optional="false" value="thresholding" label="Algorithm" > 
				<option value="peak_local_max">Peak Local Max</option>
				<option value="sparse_rbf">Sparse RBF</option>
				<option value="thresholding">Thresholding</option>
			</param>	
			<when value="peak_local_max">
				<param name="pixelDistance" type="integer" value="-1" label="Min Pixel Distance" help="Values less than 0 mean no minimum" /> 
				<param name="relativeIntensity" type="integer" value="-1" label="Min Relative Intensity" help="Values less than 0 mean no minimum" /> 
				<param name="normalization" type="boolean" checked="false" label="Normalization" />
			</when>
			<when value="sparse_rbf">
				<param name="alpha" type="float" value="0.1" label="Alpha" /> 
				<param name="tuneSNR" type="boolean" checked="false" label="Auto-tune SNR threshold" />
				<param name="alphaCand" type="text" value="3.0,5.0,10.0,15.0,20.0,25.0,30.0" label="Candidate SNR thresholds alpha for auto-tuning" help="In the format of a comma separated list of numbers" />
				<param name="chunk" type="integer" value="4096" label="Chunk Size" /> 
				<param name="gamma" type="float" value="2.0" label="Gamma" /> 
				<param name="loss" type="text" value="gaussian" label="Loss Function" />>
				<param name="maxPeaks" type="integer" value="500" label="Max Peaks" /> 
				<param name="maxSigma" type="float" value="10.0" label="Max Sigma" /> 
				<param name="minSigma" type="float" value="0.5" label="Min Sigma" /> 
				<param name="rbfShow" type="boolean" checked="false" label="Show Steps" />
			</when>
			<when value="thresholding">
				<param name="blur" type="integer" value="5" label="Blur Kernel Sigma" /> 
				<param name="erosion" type="float" value="0.85" label="Mask Relative Erosion Radius" /> 
				<param name="noise" type="float" value="0.99" label="Noise Cutoff Quantile" /> 
				<param name="kernelSize" type="integer" value="3" label="Open Kernel Size Pixels" /> 
				<param name="peakDist" type="integer" value="-1" label="Min Peak Distance Pixels" /> 
				<param name="thresholdShow" type="boolean" checked="false" label="Show Steps" />
				<conditional name="mask">
					<param name="useMask" type="boolean" checked="false" label="Use Mask File" />
					<when value="false">
					</when>
					<when value="true">
						<param format="h5" name="maskFile" type="data" label="Mask file" />
					</when>
				</conditional>
			</when>
		</conditional> 
    </inputs>
    <outputs>
		<data format="h5" label="finder.h5" name="output" from_work_dir="out/finder.h5" />
    </outputs>>
    <help><![CDATA[
        Calculates peak indices.
    ]]></help>
</tool>
