<tool id="neutrons_asrp_gsas2_prototype" name="GSAS2 Refinement Prototype" profile="22.05" version="0.11.0">
    <description></description>
    <creator>
        <person name="Marshall McDonnell"/>
        <organization url="https://www.ornl.gov/" name="ORNL"/>
    </creator>
    <requirements>
        <container type="docker" shell="/bin/bash">
            savannah.ornl.gov/asrp/gsas2_refinement:0.11
        </container>
    </requirements>
    <command detect_errors="exit_code"><![CDATA[
        export GALAXY_WORKING_DIR=`pwd` &&
        mkdir -p /tmp/portal &&
        touch $output &&
        #set gsas_ext = os.path.splitext(str($gsas_file.element_identifier))[1]
        #if not $gsas_ext
        #set gsas_ext = os.path.splitext(str($gsas_file))[1]
        #end if
        #if not $gsas_ext
        #set gsas_ext = '.gsa'
        #end if
        ln -s $gsas_file ./input$gsas_ext &&
        ln -s $prm_file ./input.instprm &&
        #for $index, $cif_file in enumerate($cif_files)
        ln -s $cif_file ./input_${index}.cif &&
        #end for
            (cd /GSAS-II/pixi && pixi run python -m gsas2_refinement.gsas2_refinement
                #for $index, $cif_file in enumerate($cif_files)
            --cif-filenames "\$GALAXY_WORKING_DIR/input_${index}.cif"
                #end for
            --gsas-filename "\$GALAXY_WORKING_DIR/input$gsas_ext"
            --instrument-params-filename "\$GALAXY_WORKING_DIR/input.instprm"
                #for $bank in $bank_ids
                --bank-ids $bank.bank_id
                #end for
                --xmin $xmin
                --xmax $xmax
                $refine_scale
                $refine_background
                #if str($background_type) != ''
                --background-type $background_type
                #end if
                #if $background_num_coeffs is not None
                --background-num-coeffs $background_num_coeffs
                #end if
                $refine_cell
                $refine_fractional_occupancy
                $refine_coordinates
                $refine_uiso
                $refine_size_strain
                $refine_sample_displacement
                #if str($sample_displacement_parameter) != ''
                --sample-displacement-parameter $sample_displacement_parameter
                #end if
                #if $num_cycles is not None
                --num-cycles $num_cycles
                #end if
                #if str($scale_factor) != ''
                --scale-factor $scale_factor
                #end if
                #if str($refinement_recipe) != ''
                --refinement-recipe $refinement_recipe
                #end if
            --output-directory /tmp/portal) &&
        mkdir -p ./portal &&
        cp -R /tmp/portal/. ./portal/
        > >(tee -a $output) 2> >(tee -a $output >&2)
    ]]></command>
    <inputs>
        <param name="cif_files" type="data_collection" collection_type="list" format="cif" label="CIF Files"/>
        <param name="gsas_file" type="data" format="txt" label="GSAS File"/>
        <param name="prm_file" type="data" format="txt" label="Instrument Parameter File"/>
        <repeat name="bank_ids" title="Bank IDs">
            <param name="bank_id" type="integer" label="Bank ID" value="0"/>
        </repeat>
        <param name="xmin" type="float" label="Left bound" value="0"/>
        <param name="xmax" type="float" label="Right bound" value="0"/>
        <param name="num_cycles" type="integer" label="Number of cycles" optional="true"/>
        <param name="refine_scale" type="boolean" label="Refine phase fraction / HAP scale" truevalue="--refine-scale-on" falsevalue="--refine-scale-off" checked="true"/>
        <param name="scale_factor" type="float" label="Initial phase fraction / HAP scale" optional="true"/>
        <param name="refine_background" type="boolean" label="Refine background" truevalue="--refine-background-on" falsevalue="--refine-background-off" checked="true"/>
        <param name="background_type" type="text" label="Background model type" value="chebyschev"/>
        <param name="background_num_coeffs" type="integer" label="Background coefficient count" value="6"/>
        <param name="refine_cell" type="boolean" label="Refine cell parameters" truevalue="--refine-cell-on" falsevalue="--refine-cell-off" checked="true"/>
        <param name="refine_fractional_occupancy" type="boolean" label="Refine fractional occupancy" truevalue="--refine-fractional-occupancy-on" falsevalue="--refine-fractional-occupancy-off" checked="false"/>
        <param name="refine_coordinates" type="boolean" label="Refine atom coordinates" truevalue="--refine-coordinates-on" falsevalue="--refine-coordinates-off" checked="false"/>
        <param name="refine_uiso" type="boolean" label="Refine Uiso values" truevalue="--refine-uiso-on" falsevalue="--refine-uiso-off" checked="true"/>
        <param name="refine_size_strain" type="boolean" label="Refine crystallite size and microstrain" truevalue="--refine-size-strain-on" falsevalue="--refine-size-strain-off" checked="false"/>
        <param name="refine_sample_displacement" type="boolean" label="Refine sample displacement" truevalue="--refine-sample-displacement-on" falsevalue="--refine-sample-displacement-off" checked="false"/>
        <param name="sample_displacement_parameter" type="select" label="Sample displacement parameter">
            <option value="DisplaceX" selected="true">DisplaceX</option>
            <option value="Shift">Shift</option>
        </param>
        <param name="refinement_recipe" type="data" format="txt" label="Advanced refinement recipe JSON (escape hatch)" optional="true"/>
    </inputs>
    <outputs>
        <collection type="list" name="output_collection1" label="GSAS2 refinement output">
            <discover_datasets format="binary" pattern="__designation__" directory="portal"/>
        </collection>
        <collection type="list" name="refinement_plots" label="GSAS2 refinement plots">
            <discover_datasets format="png" pattern="(?P&lt;designation&gt;.*\.png)" directory="portal" visible="true"/>
        </collection>
        <data format="txt" name="output" label="GSAS2 console output"></data>
    </outputs>
    <help><![CDATA[
        Runs GSAS2 Rietveld refinement.
    ]]></help>
</tool>
