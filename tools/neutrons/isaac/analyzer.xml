<tool id="neutrons_isaac_analyzer" name="Analyzer" version="0.1.0" profile="22.01">
    <creator>
        <person name="Mat Doucet"/>
        <organization url="https://www.ornl.gov/" name="ORNL"/>
    </creator>
    <requirements>
        <container type="docker" shell="/bin/bash">ghcr.io/neutrons-ai/aure:sha-a7a7d76</container>
        <credentials name="llm_credentials" version="1.0"
                     label="LLM Credentials"
                     description="Credentials for accessing LLM API.">
            <secret name="llm_api_key"
                    inject_as_env="LLM_API_KEY"
                    optional="false"
                    label="LLM API Key"
                    description="Your LLM API key."/>
        </credentials>
    </requirements>
    <inputs>
        <param name="reflectivity_file" type="data" format="txt" label="Reflectivity File"/>
        <param name="prompt" type="text" value="Cu/Ti bilayer on Si in dTHF" label="Prompt"/>
        <param name="llm_provider" type="text" value="local" label="LLM Provider"/>
        <param name="llm_model" type="text" value="gpt-4" label="LLM Model"/>
        <param name="llm_base_url" type="text" value="https://aoai-eastus-bead.openai.azure.com/openai/v1/" label="LLM Endpoint"/>
    </inputs>
    <outputs>
        <data format="txt" name="output" label="Analyzer Console Output"></data>
        <data name="output_model" format="txt" label="Analyzer Model"></data>
        <data name="out_gz" format="gz" label="Analyzer Results"></data>
    </outputs>
    <command detect_errors="exit_code"><![CDATA[
        mkdir output &&
        export LLM_PROVIDER=$llm_provider &&
        export LLM_MODEL=$llm_model &&
        export LLM_BASE_URL=$llm_base_url &&
        aure analyze $reflectivity_file "$prompt" -o ./output
                > >(tee -a $output) 2> >(tee -a $output >&2) &&
        LAST_ITER=`ls -d output/refl1d_output/fit_iter*_dream | sort -V | tail -n 1` &&
        cp \$LAST_ITER/problem-1-exp*.json $output_model &&
        tar -czvf $out_gz output
    ]]></command>
</tool>