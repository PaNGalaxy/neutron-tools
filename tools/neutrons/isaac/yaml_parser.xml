<tool id="isaac_yaml_parser" name="YAML to Collection Splitter" version="1.0.0" profile="22.01">
    <description>Parses a master YAML file into two collections: NeXus files and individual configs</description>
    
    <requirements>
        <container type="docker">ghcr.io/isaac-neutrons/ndip-workflows:latest</container>
    </requirements>

    <command detect_errors="exit_code"><![CDATA[
        yaml-parser '$input_yaml'
            --nexus-dir './nexus_outputs'
            --config-dir './config_outputs'
    ]]></command>

    <inputs>
        <param name="input_yaml" type="data" format="yaml,txt" label="Master Batch YAML" help="A YAML file where the top-level element is a list." />
    </inputs>

    <outputs>
        <collection name="nexus_collection" type="list" label="NeXus Files from ${on_string}">
            <discover_datasets pattern="(?P&lt;designation&gt;.*)\.nxs\.h5" directory="nexus_outputs" format="h5" />
        </collection>
        <collection name="config_collection" type="list" label="Batch Configs from ${on_string}">
            <discover_datasets pattern="(?P&lt;designation&gt;.*)\.json" directory="config_outputs" format="json" />
        </collection>
    </outputs>

    <tests>
    </tests>

</tool>
