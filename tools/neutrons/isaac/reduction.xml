<tool id="neutrons_isaac_reduction" name="Reduction" version="0.1.0" profile="22.01">
    <creator>
        <person name="Mat Doucet"/>
        <organization url="https://www.ornl.gov/" name="ORNL"/>
    </creator>

    <requirements>
        <container type="docker" shell="/bin/bash">ghcr.io/mdoucet/analyzer:sha-5f24d3c</container>
    </requirements>

    <inputs>
        <param name="input_file" type="data" format="h5" label="Input NeXus File"/>
        <param name="template_file" type="data" label="Input Template File"/>
        <param name="data_dir" type="text" value="/SNS/REF_L/IPTS-34347/nexus" label="Data directory"/>
    </inputs>

    <outputs>
        <data format="txt" name="output" label="Reduction Console Output"></data>
        <data format="txt" name="reflectivity" label="Reflectivity File"></data>
    </outputs>

    <command detect_errors="exit_code"><![CDATA[
        mkdir output &&
        export HOME=/root &&
        ln -s $data_dir /app/data &&
        echo "running reduction..." &&
        pixi run --as-is --manifest-path /app python /app/scripts/mantid/simple_reduction.py --event-file $input_file --template $template_file --output-dir output
                > >(tee -a $output) 2> >(tee -a $output >&2) &&
        ls output/ &&
        cp output/REFL*combined_data_auto.txt $reflectivity
    ]]></command>
</tool>